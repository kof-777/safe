<script>
  const btn = document.getElementById("generateBtn");

  btn.addEventListener("click", () => {
    const input = document.getElementById("url").value.trim();

    if (!input) {
      alert("Masukkan URL dulu!");
      return;
    }

    try {
      new URL(input);
    } catch {
      alert("URL tidak valid!");
      return;
    }

    // 🔥 encode FIX
    const encoded = encodeURIComponent(btoa(input));

    // 🔥 PENTING: pakai origin biar tidak salah path
    const safelink = window.location.origin + "/safelink/?go=" + encoded;

    document.getElementById("result").innerHTML =
      `<a href="${safelink}" target="_blank">${safelink}</a>`;
  });
</script>
